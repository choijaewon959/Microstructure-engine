.DS_Store
.env
.env.*
!.env.example
.venv/
venv/
__pycache__/
.pytest_cache/
*.py[cod]
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Keep raw market data local unless explicitly requested.
data/raw/
data/raw/**/*.parquet

# Generated local outputs can be reproduced from raw data.
data/processed/*
!data/processed/.gitkeep
data/features/*
!data/features/.gitkeep

# Sample data is commit-safe by design.
!data/sample/
